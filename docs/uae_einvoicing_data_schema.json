        "field_number": 11,
        "name": "Seller electronic address",
        "section": "4.1",
        "cardinality": "1..1",
        "applies_to": ["tax_invoice", "commercial_xml"],
        "semantics": {
          "identifier_name": "TIN",
          "definition": "10-digit TIN; if TRN exists then first 10 digits of TRN; otherwise obtained via FTA registration for entities in scope that are not registered for a tax type",
          "format": "^[0-9]{10}$"
        }
      },

      {
        "field_number": 12,
        "name": "Seller electronic identifier",
        "section": "4.1",
        "cardinality": "1..1",
        "applies_to": ["tax_invoice", "commercial_xml"],
        "semantics": {
          "type": "scheme_prefix",
          "fixed_value": "0235",
          "meaning": "UAE scheme identifier used with participant identifiers (e.g., 0235:<TIN>)"
        }
      },

      { "field_number": 13, "name": "Seller legal registration identifier", "section": "4.1", "cardinality": "1..1", "applies_to": ["tax_invoice", "commercial_xml"] },
      { "field_number": 14, "name": "Seller legal registration identifier type", "section": "4.1", "cardinality": "1..1", "applies_to": ["tax_invoice", "commercial_xml"] },

      {
        "field_number": 15,
        "name": "Seller tax registration identifier",
        "section": "4.1",
        "cardinality": "1..1",
        "applies_to": ["tax_invoice", "commercial_xml"],
        "semantics": {
          "type": "conditional_identifier",
          "cases": [
            { "when": "seller_is_uae_vat_registered == true", "use": "TRN", "format": "^[0-9]{15}$" },
            { "when": "seller_is_uae_vat_registered == false", "use": "TIN", "format": "^[0-9]{10}$" }
          ]
        }
      },

